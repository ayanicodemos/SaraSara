{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SaraSara",
  "version": "1.1.0",
  "identifier": "com.sarasara.writer",
  "build": {
    "frontendDist": "../dist",
    "beforeBuildCommand": "mkdir -p dist && cp -r src/languages dist/ && cp src/index.html src/app.js src/styles.css src/icon.svg src/favicon.ico dist/"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "SaraSara",
        "width": 1280,
        "height": 768,
        "resizable": true,
        "maximizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
