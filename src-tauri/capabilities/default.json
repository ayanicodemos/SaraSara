{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "dialog:default",
    "fs:default",
    {
      "identifier": "fs:allow-read-text-file",
      "allow": [
        { "path": "$HOME/*" },
        { "path": "$HOME/**" },
        { "path": "$APPDATA/*" },
        { "path": "$APPDATA/**" },
        { "path": "$DOCUMENT/*" },
        { "path": "$DOCUMENT/**" },
        { "path": "$DOWNLOAD/*" },
        { "path": "$DOWNLOAD/**" },
        { "path": "$DESKTOP/*" },
        { "path": "$DESKTOP/**" }
      ]
    },
    {
      "identifier": "fs:allow-write-text-file",
      "allow": [
        { "path": "$HOME/*" },
        { "path": "$HOME/**" },
        { "path": "$APPDATA/*" },
        { "path": "$APPDATA/**" },
        { "path": "$DOCUMENT/*" },
        { "path": "$DOCUMENT/**" },
        { "path": "$DOWNLOAD/*" },
        { "path": "$DOWNLOAD/**" },
        { "path": "$DESKTOP/*" },
        { "path": "$DESKTOP/**" }
      ]
    },
    {
      "identifier": "fs:allow-read-file",
      "allow": [
        { "path": "$HOME/*" },
        { "path": "$HOME/**" },
        { "path": "$APPDATA/*" },
        { "path": "$APPDATA/**" },
        { "path": "$DOCUMENT/*" },
        { "path": "$DOCUMENT/**" },
        { "path": "$DOWNLOAD/*" },
        { "path": "$DOWNLOAD/**" },
        { "path": "$DESKTOP/*" },
        { "path": "$DESKTOP/**" }
      ]
    },
    {
      "identifier": "fs:allow-write-file",
      "allow": [
        { "path": "$HOME/*" },
        { "path": "$HOME/**" },
        { "path": "$APPDATA/*" },
        { "path": "$APPDATA/**" },
        { "path": "$DOCUMENT/*" },
        { "path": "$DOCUMENT/**" },
        { "path": "$DOWNLOAD/*" },
        { "path": "$DOWNLOAD/**" },
        { "path": "$DESKTOP/*" },
        { "path": "$DESKTOP/**" }
      ]
    },
    {
      "identifier": "fs:allow-mkdir",
      "allow": [
        { "path": "$HOME/*" },
        { "path": "$HOME/**" },
        { "path": "$APPDATA/*" },
        { "path": "$APPDATA/**" },
        { "path": "$DOCUMENT/*" },
        { "path": "$DOCUMENT/**" },
        { "path": "$DOWNLOAD/*" },
        { "path": "$DOWNLOAD/**" },
        { "path": "$DESKTOP/*" },
        { "path": "$DESKTOP/**" }
      ]
    },
    {
      "identifier": "fs:allow-copy-file",
      "allow": [
        { "path": "$HOME/*" },
        { "path": "$HOME/**" },
        { "path": "$APPDATA/*" },
        { "path": "$APPDATA/**" },
        { "path": "$DOCUMENT/*" },
        { "path": "$DOCUMENT/**" },
        { "path": "$DOWNLOAD/*" },
        { "path": "$DOWNLOAD/**" },
        { "path": "$DESKTOP/*" },
        { "path": "$DESKTOP/**" }
      ]
    },
    {
      "identifier": "fs:allow-remove",
      "allow": [
        { "path": "$HOME/*" },
        { "path": "$HOME/**" },
        { "path": "$APPDATA/*" },
        { "path": "$APPDATA/**" },
        { "path": "$DOCUMENT/*" },
        { "path": "$DOCUMENT/**" },
        { "path": "$DOWNLOAD/*" },
        { "path": "$DOWNLOAD/**" },
        { "path": "$DESKTOP/*" },
        { "path": "$DESKTOP/**" }
      ]
    }
  ]
}
